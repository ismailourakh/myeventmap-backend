generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    String                 @id @default(uuid())
  name                  String
  email                 String                 @unique
  passwordHash          String
  role                  UserRole               @default(PARTICIPANT)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  events                Event[]
  application           OrganizerApplication?
  approvedApplications  OrganizerApplication[] @relation("ApplicationApprovedBy")
  bookings              Booking[]
}

model OrganizerApplication {
  id                String                      @id @default(uuid())
  userId            String                      @unique
  message           String?
  status            OrganizerApplicationStatus  @default(PENDING)

  approvedByAdminId String?
  approvedAt        DateTime?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  approvedByAdmin   User? @relation("ApplicationApprovedBy", fields: [approvedByAdminId], references: [id])

  @@index([status, createdAt])
  @@index([approvedByAdminId])
}

model Event {
  id              String      @id @default(uuid())
  title           String
  description     String?
  imageUrl        String?
  location        String?
  postcode        String?
  includesFood    Boolean     @default(false)
  startDate       DateTime
  endDate         DateTime
  status          EventStatus @default(DRAFT)
  capacity        Int
  availableSeats  Int
  organizerId     String
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  organizer       User        @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  bookings        Booking[]

  @@index([status, startDate])
  @@index([organizerId])
  @@index([postcode])
}

model Booking {
  id        String   @id @default(uuid())
  userId    String
  eventId   String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@index([eventId])
  @@index([userId])
}

enum UserRole {
  PARTICIPANT
  ORGANIZER
  ADMIN
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
}

enum OrganizerApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}